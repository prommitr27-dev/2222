<?xml version="1.0"?>
<robot name="my_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="body_link_x_dim" value="0.6"/>
  <xacro:property name="body_link_y_dim" value="0.4"/>
  <xacro:property name="body_link_z_dim" value="0.2"/>
  <xacro:property name="body_mass" value="50.0"/>
  <xacro:property name="wheel_link_radius" value="0.15"/>
  <xacro:property name="wheel_link_length" value="0.08"/>
  <xacro:property name="wheel_mass" value="2.0"/>
  <xacro:property name="wheel_link_z_location" value="-0.1"/>

  <xacro:include filename="gazebo_control.xacro" />

  <xacro:macro name="inertia_box" params="mass x y z *origin">
    <inertial>
      <xacro:insert_block name="origin"/>
      <mass value="${mass}"/>
      <inertia ixx="${(1/12) * mass * (y*y + z*z)}" ixy="0.0" ixz="0.0" iyy="${(1/12) * mass * (x*x + z*z)}" iyz="0.0" izz="${(1/12) * mass * (x*x + y*y)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertial_cylinder" params="mass length radius *origin">
    <inertial>
      <xacro:insert_block name="origin"/>
      <mass value="${mass}"/>
      <inertia ixx="${(1/12) * mass * (3*radius*radius + length*length)}" ixy="0.0" ixz="0.0" iyy="${(1/12) * mass * (3*radius*radius + length*length)}" iyz="0.0" izz="${(1/2) * mass * (radius*radius)}"/>
    </inertial>
  </xacro:macro>

  <link name="base_link"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="body_link"/>
    <origin xyz="0 0 ${wheel_link_radius - wheel_link_z_location}" rpy="0 0 0"/>
  </joint>
   <joint name="base_footprint_joint" type="fixed">
   <parent link="base_link"/>
   <child link="base_footprint"/>
   <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_footprint">
  </link>

  <link name="body_link">
    <visual>
      <geometry><box size="${body_link_x_dim} ${body_link_y_dim} ${body_link_z_dim}"/></geometry>
      <material name="blue"><color rgba="0 0 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><box size="${body_link_x_dim} ${body_link_y_dim} ${body_link_z_dim}"/></geometry>
    </collision>
    <xacro:inertia_box mass="${body_mass}" x="${body_link_x_dim}" y="${body_link_y_dim}" z="${body_link_z_dim}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertia_box>
  </link>
  <gazebo reference="body_link"><material>Gazebo/Blue</material></gazebo>

  <xacro:macro name="wheel" params="name x_reflect y_reflect f_mu1 f_mu2">
    <joint name="${name}_joint" type="continuous">
      <parent link="body_link"/>
      <child link="${name}_link"/>
      <origin xyz="${x_reflect * (body_link_x_dim/2 - wheel_link_radius)} ${y_reflect * (body_link_y_dim/2 + wheel_link_length/2)} ${wheel_link_z_location}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
    <link name="${name}_link">
      <visual>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <geometry><cylinder length="${wheel_link_length}" radius="${wheel_link_radius}"/></geometry>
        <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
      </visual>
      <collision>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <geometry><sphere radius="${wheel_link_radius}"/></geometry>
      </collision>
      <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_link_length}" radius="${wheel_link_radius}">
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </xacro:inertial_cylinder>
    </link>
    <gazebo reference="${name}_link">
      <material>Gazebo/Black</material>
      <mu1>${f_mu1}</mu1>
      <mu2>${f_mu2}</mu2>
    </gazebo>
  </xacro:macro>

  <!-- 🌟 ปล่อยล้อหน้าให้ลื่นเป็นปกติ แต่เพิ่มความหนึบให้ล้อหลังเพื่อปีนเนินและเลี้ยวแบบไม่ไถล -->
  <xacro:wheel name="front_left"  x_reflect="1"  y_reflect="1"  f_mu1="0.001" f_mu2="0.001" />
  <xacro:wheel name="front_right" x_reflect="1"  y_reflect="-1" f_mu1="0.001" f_mu2="0.001" />
  <xacro:wheel name="back_left"   x_reflect="-1" y_reflect="1"  f_mu1="200.0" f_mu2="200.0" />
  <xacro:wheel name="back_right"  x_reflect="-1" y_reflect="-1" f_mu1="200.0" f_mu2="200.0" />

  <joint name="arm_base_joint" type="revolute">
    <parent link="arm_mount_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="500.0" velocity="1.0"/>
    <dynamics damping="10.0" friction="1.0"/>
  </joint>

  <link name="arm_base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.1"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.1"/></geometry>
    </collision>
    <xacro:inertial_cylinder mass="2.0" radius="0.06" length="0.1">
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="arm_base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="1000.0" velocity="0.5"/>
    <dynamics damping="50.0" friction="3.0"/>
  </joint>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.4"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.4"/></geometry>
    </collision>
    <xacro:inertia_box mass="3.0" x="0.05" y="0.05" z="0.4">
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
    </xacro:inertia_box>
  </link>
  
  <gazebo reference="arm_base_link"><material>Gazebo/White</material></gazebo>
  <gazebo reference="shoulder_link"><material>Gazebo/Blue</material></gazebo>
  <link name="arm_mount_link">
    <visual>
      <geometry><cylinder radius="0.08" length="0.04"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.08" length="0.04"/></geometry>
    </collision>
    <xacro:inertial_cylinder mass="5.0" radius="0.08" length="0.04">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
  </link>

  <joint name="arm_mount_joint" type="fixed">
    <parent link="body_link"/>
    <child link="arm_mount_link"/>
    <origin xyz="0.1 0 ${body_link_z_dim/2}" rpy="0 0 0"/>
  </joint>

  <joint name="forearm_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="800.0" velocity="1.0"/>
    <dynamics damping="80.0" friction="5.0"/>
  </joint>

  <link name="forearm_link">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.3"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.3"/></geometry>
    </collision>
    <xacro:inertia_box mass="2.0" x="0.04" y="0.04" z="0.3">
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
    </xacro:inertia_box>
  </link>

  <joint name="hand_joint" type="fixed">
    <parent link="forearm_link"/>
    <child link="hand_link"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
  </joint>

  <link name="hand_link">
    <visual>
      <geometry><box size="0.04 0.6 0.04"/></geometry>
      <material name="blue"/>
    </visual>
    <xacro:inertia_box mass="1.0" x="0.04" y="0.6" z="0.04">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertia_box>
  </link>

 <xacro:macro name="finger" params="name y_reflect">
    <joint name="${name}_joint" type="prismatic">
      <parent link="hand_link"/>
      <child link="${name}_link"/>
      <origin xyz="0.1 ${y_reflect * 0.25} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.05" upper="0.08" effort="500.0" velocity="0.5"/>
    </joint>
  
   <link name="${name}_link">
      <visual>
        <geometry><box size="0.2 0.02 0.1"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry><box size="0.2 0.02 0.1"/></geometry>
      </collision>
      <xacro:inertia_box mass="0.5" x="0.2" y="0.02" z="0.1">
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </xacro:inertia_box>
    </link>
  </xacro:macro>

  <xacro:finger name="left_finger" y_reflect="1" />
  <xacro:finger name="right_finger" y_reflect="-1" />

  <xacro:macro name="inertia_cylinder" params="mass length radius *origin">
        <inertial>
            <xacro:insert_block name="origin"/>
            <mass value="${mass}" />
            <inertia ixx="${(1/12) * mass * (3*radius*radius + length*length)}" ixy="0.0" ixz="0.0"
                     iyy="${(1/12) * mass * (3*radius*radius + length*length)}" iyz="0.0"
                     izz="${(1/2) * mass * (radius*radius)}" />
        </inertial>
    </xacro:macro>
    
  <joint name="laser_joint" type="fixed">
        <parent link="body_link"/>
        <child link="laser_frame"/>
        <origin xyz="0.21 0 0.12" rpy="0 0 0"/> </joint>

    <link name="laser_frame">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
        </collision>
        <xacro:inertia_cylinder mass="0.1" length="0.04" radius="0.05">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertia_cylinder>
    </link>

    <gazebo reference="laser_frame">
        <material>Gazebo/Red</material>
        <sensor name="laser" type="ray">
            <pose> 0 0 0 0 0 0 </pose>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <min_angle>-3.14</min_angle>
                        <max_angle>3.14</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.2</min>
                    <max>12.0</max>
                </range>
            </ray>
            <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
            <ros>
                <remapping>~/out:=scan</remapping>
            </ros>
            <output_type>sensor_msgs/LaserScan</output_type>
            <frame_name>laser_frame</frame_name>
        </plugin>
        </sensor>
    </gazebo>
    <joint name="imu_joint" type="fixed">
    <parent link="body_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>
  <link name="imu_link"/>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
      <always_on>true</always_on>
      <update_rate>100</update_rate>
    </sensor>
  </gazebo>
    
</robot>
